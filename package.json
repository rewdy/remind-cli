{
  "name": "@rewdy/remind-cli",
  "version": "0.1.0",
  "description": "Terminal reminders that show up when you open a new shell",
  "author": "Andrew Meyer <andrew@rewdy.com>",
  "license": "MIT",
  "homepage": "https://github.com/rewdy/remind-cli",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rewdy/remind-cli.git"
  },
  "keywords": [
    "cli",
    "productivity",
    "reminder",
    "terminal"
  ],
  "bin": {
    "remind": "dist/remind.js"
  },
  "files": [
    "dist/"
  ],
  "type": "module",
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "node esbuild.config.mjs",
    "test": "bun test",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=22"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org/"
  },
  "dependencies": {
    "@clack/prompts": "latest",
    "better-sqlite3": "12.9.0",
    "date-fns": "latest",
    "ink": "latest",
    "react": "latest",
    "react-devtools-core": "latest"
  },
  "devDependencies": {
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@semantic-release/changelog": "6.0.3",
    "@semantic-release/git": "10.0.1",
    "@types/better-sqlite3": "7.6.13",
    "@types/bun": "latest",
    "@types/react": "latest",
    "esbuild": "0.28.0",
    "oxfmt": "latest",
    "semantic-release": "25.0.3",
    "typescript": "^5"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  }
}
