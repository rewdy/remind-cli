{
  "name": "@rewdy/remind-cli",
  "version": "0.1.0",
  "description": "Terminal reminders that show up when you open a new shell",
  "type": "module",
  "private": false,
  "bin": {
    "remind": "./dist/remind"
  },
  "files": [
    "dist/remind"
  ],
  "scripts": {
    "dev": "bun run src/index.ts",
    "build": "bun build --compile --target=bun src/index.ts --outfile dist/remind",
    "test": "bun test",
    "format": "oxfmt .",
    "typecheck": "tsc --noEmit"
  },
  "keywords": ["cli", "reminder", "terminal", "productivity"],
  "license": "MIT",
  "dependencies": {
    "@clack/prompts": "latest",
    "date-fns": "latest",
    "ink": "latest",
    "react": "latest",
    "react-devtools-core": "latest"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "@types/react": "latest",
    "oxfmt": "latest",
    "typescript": "^5"
  }
}
